# ==============================================================================
# Factura CR API - Variables de Entorno
# ==============================================================================

# Entorno (development, staging, production)
APP_ENV=development
APP_DEBUG=true

# ==============================================================================
# Factura CR API - Variables de Entorno
# ==============================================================================

# Entorno (development, staging, production)
APP_ENV=development
APP_DEBUG=true

# Seguridad
# Generar una clave segura con: openssl rand -hex 32
JWT_SECRET=tu_jwt_secret_super_seguro_aqui_1234
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 horas

# Base de Datos (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres.xxxxx:password@db.supabase.com:5432/postgres
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres.xxxxx:password@db.supabase.com:5432/postgres

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# PayPal (para suscripciones)
PAYPAL_CLIENT_ID=sb-tu_client_id_de_sandbox
PAYPAL_SECRET=tu_secreto_de_sandbox_paypal

# Hacienda API (Certificados y URLs)
HACIENDA_ENV=sandbox
# HACIENDA_ENV=production
# Hacienda API (Sandbox)
HACIENDA_ID_SANDBOX=tu_client_id_hacienda_sandbox
HACIENDA_PASS_SANDBOX=tu_password_hacienda_sandbox
CERT_SANDBOX_PATH=path/to/cert.p12
CERT_SANDBOX_PIN=1234


# URLs de Frontend Permitidas (CORS)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Hub -> Module exchange
HUB_TOKEN_SHARED_SECRET=replace_with_same_secret_used_by_hub_module_token_secret
HUB_TOKEN_ISSUER=app.zonasurtech.online
HUB_TOKEN_AUDIENCE=zonasurtech-module
HUB_TOKEN_ALGORITHM=HS256
HUB_EXPECTED_MODULE_KEY=billing
MODULE_SESSION_COOKIE_NAME=fac_session
MODULE_SESSION_COOKIE_SAMESITE=lax
MODULE_SESSION_COOKIE_SECURE=false
MODULE_DASHBOARD_PATH=/dashboard
MODULE_AUTH_REPLAY_PREFIX=fac:exchange:jti
