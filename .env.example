# ============================================================
# Factura CR — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values

# ─── App ────────────────────────────────────────────────────
APP_NAME="Factura CR"
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=your-super-secret-key-change-in-production

# ─── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database (Direct PostgreSQL) ────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/factura_cr

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://:password@localhost:6379/0
REDIS_PASSWORD=your_secure_redis_password_here
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── Hacienda Costa Rica ─────────────────────────────────────
# Ambiente: api-sandbox.comprobanteselectronicos.go.cr | api.comprobanteselectronicos.go.cr
HACIENDA_API_URL=https://api-sandbox.comprobanteselectronicos.go.cr/recepcion/v1
HACIENDA_TOKEN_URL=https://idp.comprobanteselectronicos.go.cr/auth/realms/rut-stag/protocol/openid-connect/token
HACIENDA_CLIENT_ID=your-client-id
HACIENDA_CLIENT_SECRET=your-client-secret
HACIENDA_USERNAME=your-cedula
HACIENDA_PASSWORD=your-atv-password

# ─── Firma Digital ───────────────────────────────────────────
# Ruta al certificado .p12 (firma digital BCCR)
FIRMA_DIGITAL_PATH=./certs/firma.p12
FIRMA_DIGITAL_PIN=your-pin

# ─── Email (Notificaciones) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@email.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@facturacr.com

# ─── Storage (Supabase / S3) ─────────────────────────────────
STORAGE_BUCKET=facturas-pdf
STORAGE_REGION=us-east-1

# ─── Nuxt Dashboard ──────────────────────────────────────────
NUXT_PUBLIC_API_BASE=http://localhost:8000
NUXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NUXT_PUBLIC_SUPABASE_KEY=your-anon-key
