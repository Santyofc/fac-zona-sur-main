// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ────────────────────────────────────────────────────────────
// MODEL: Company (Tenant)
// ────────────────────────────────────────────────────────────
model Company {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  name            String
  tradeName       String?  @map("trade_name")
  cedulaType      String   @default("FISICA") @map("cedula_type")
  cedulaNumber    String   @unique @map("cedula_number")

  email           String   @unique
  phone           String?
  website         String?

  province        String?
  canton          String?
  district        String?
  address         String?

  haciendaUser    String?  @map("hacienda_user")
  haciendaPassEnc String?  @map("hacienda_pass_encrypted")
  certPath        String?  @map("cert_path")
  certPinEnc      String?  @map("cert_pin_encrypted")

  invoicePrefix   String   @default("E-") @map("invoice_prefix")
  consecutiveNum  BigInt   @default(1) @map("consecutive_num")
  economicActivity String? @map("economic_activity")
  
  plan            String   @default("free")
  planExpiresAt   DateTime? @map("plan_expires_at")
  isActive        Boolean  @default(true) @map("is_active")

  users           User[]
  clients         Client[]
  products        Product[]
  invoices        Invoice[]
  payments        Payment[]

  @@map("companies")
}

// ────────────────────────────────────────────────────────────
// MODEL: User
// ────────────────────────────────────────────────────────────
model User {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  companyId       String   @map("company_id") @db.Uuid
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  email           String   @unique
  passwordHash    String?  @map("password_hash")
  fullName        String   @map("full_name")
  avatarUrl       String?  @map("avatar_url")
  
  role            String   @default("viewer")
  isActive        Boolean  @default(true) @map("is_active")
  lastLoginAt     DateTime? @map("last_login_at")
  
  approvedPayments Payment[] @relation("ApprovedBy")

  @@map("users")
}

// ────────────────────────────────────────────────────────────
// MODEL: Client
// ────────────────────────────────────────────────────────────
model Client {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  companyId       String   @map("company_id") @db.Uuid
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name            String
  cedulaType      String   @default("FISICA") @map("cedula_type")
  cedulaNumber    String?  @map("cedula_number")
  
  email           String?
  phone           String?
  
  province        String?
  canton          String?
  district        String?
  address         String?
  
  notes           String?
  isActive        Boolean  @default(true) @map("is_active")

  invoices        Invoice[]

  @@map("clients")
}

// ────────────────────────────────────────────────────────────
// MODEL: Product
// ────────────────────────────────────────────────────────────
model Product {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  companyId       String   @map("company_id") @db.Uuid
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  code            String?
  cabysCode       String?  @map("cabys_code")
  name            String
  description     String?
  
  unitPrice       Decimal  @default(0) @map("unit_price") @db.Decimal(12, 5)
  currency        String   @default("CRC")
  taxRate         Decimal  @default(13.0) @map("tax_rate") @db.Decimal(5, 2)
  unitMeasure     String   @default("Sp") @map("unit_measure")
  
  isActive        Boolean  @default(true) @map("is_active")

  invoiceItems    InvoiceItem[]

  @@map("products")
}

// ────────────────────────────────────────────────────────────
// MODEL: Invoice
// ────────────────────────────────────────────────────────────
model Invoice {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  companyId       String   @map("company_id") @db.Uuid
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId        String?  @map("client_id") @db.Uuid
  client          Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdBy       String?  @map("created_by") @db.Uuid

  consecutive     String
  clave           String?  @unique
  docType         String   @default("FE") @map("doc_type")
  
  issueDate       DateTime @default(now()) @map("issue_date")
  dueDate         DateTime? @map("due_date")
  
  currency        String   @default("CRC")
  exchangeRate    Decimal  @default(1.0) @map("exchange_rate") @db.Decimal(12, 5)
  subtotal        Decimal  @default(0) @db.Decimal(12, 5)
  taxTotal        Decimal  @default(0) @map("tax_total") @db.Decimal(12, 5)
  discountTotal   Decimal  @default(0) @map("discount_total") @db.Decimal(12, 5)
  total           Decimal  @default(0) @db.Decimal(12, 5)
  
  saleCondition   String   @default("01") @map("sale_condition")
  paymentMethod   String   @default("01") @map("payment_method")
  creditTermDays  Int?     @default(0) @map("credit_term_days")
  
  status          String   @default("draft")
  notes           String?
  
  items           InvoiceItem[]
  haciendaDoc     HaciendaDocument?

  @@map("invoices")
}

// ────────────────────────────────────────────────────────────
// MODEL: InvoiceItem
// ────────────────────────────────────────────────────────────
model InvoiceItem {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  invoiceId       String   @map("invoice_id") @db.Uuid
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId       String?  @map("product_id") @db.Uuid
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  lineNumber     Int      @map("line_number")
  cabysCode      String?  @map("cabys_code")
  description    String
  unitMeasure    String   @default("Sp") @map("unit_measure")
  quantity       Decimal  @default(1) @db.Decimal(12, 5)
  unitPrice      Decimal  @map("unit_price") @db.Decimal(12, 5)
  discountPct    Decimal? @default(0) @map("discount_pct") @db.Decimal(5, 2)
  discountAmount Decimal? @default(0) @map("discount_amount") @db.Decimal(12, 5)
  subtotal       Decimal  @db.Decimal(12, 5)
  taxRate        Decimal  @default(13.0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount      Decimal  @map("tax_amount") @db.Decimal(12, 5)
  total          Decimal  @db.Decimal(12, 5)

  @@map("invoice_items")
}

// ────────────────────────────────────────────────────────────
// MODEL: HaciendaDocument
// ────────────────────────────────────────────────────────────
model HaciendaDocument {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  invoiceId       String   @unique @map("invoice_id") @db.Uuid
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  xmlContent      String?  @map("xml_content")
  xmlSigned       String?  @map("xml_signed")
  xmlFilename     String?  @map("xml_filename")

  submissionDate  DateTime? @map("submission_date")
  haciendaStatus  String?   @map("hacienda_status")
  haciendaMsg     String?   @map("hacienda_msg")
  haciendaDetail  String?   @map("hacienda_detail")
  
  responseXml     String?   @map("response_xml")
  responseDate    DateTime? @map("response_date")
  
  pdfUrl          String?   @map("pdf_url")
  pdfGeneratedAt  DateTime? @map("pdf_generated_at")
  
  sendAttempts    Int       @default(0) @map("send_attempts")
  lastAttemptAt   DateTime? @map("last_attempt_at")

  @@map("hacienda_documents")
}

// ────────────────────────────────────────────────────────────
// MODEL: Payment
// ────────────────────────────────────────────────────────────
model Payment {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  companyId       String   @map("company_id") @db.Uuid
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  amount          Decimal  @db.Decimal(12, 2)
  currency        String   @default("USD")
  paymentMethod   String   @map("payment_method")
  
  referenceId     String?  @map("reference_id")
  receiptUrl      String?  @map("receipt_url")
  
  status          String   @default("pending")
  monthsAdded     Int      @default(1) @map("months_added")
  
  approvedAt      DateTime? @map("approved_at")
  approvedById    String?   @map("approved_by") @db.Uuid
  approvedBy      User?     @relation("ApprovedBy", fields: [approvedById], references: [id])
  notes           String?

  @@map("payments")
}
