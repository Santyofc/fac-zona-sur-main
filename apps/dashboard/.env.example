# ==============================================================================
# Dashboard - Variables de Entorno (Nuxt 3)
# ==============================================================================

# URL local de la API (FastAPI) al levantarla con uvicorn main:app
NUXT_PUBLIC_API_URL=http://localhost:8000

# Client ID de PayPal (sandbox) para el SDK de JS
NUXT_PUBLIC_PAYPAL_CLIENT_ID=sb-tu_client_id_de_sandbox

# Nombre del Proyecto
NUXT_PUBLIC_APP_NAME="Factura CR"
