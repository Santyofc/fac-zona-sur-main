{
  "name": "factura-cr",
  "version": "1.0.0",
  "private": true,
  "description": "Plataforma de facturación electrónica para Costa Rica",
  "scripts": {
    "dev": "pnpm --parallel run dev",
    "dev:dashboard": "pnpm --filter @factura-cr/dashboard dev",
    "dev:web": "pnpm --filter @factura-cr/web dev",
    "build": "pnpm --parallel run build",
    "lint": "pnpm --parallel run lint"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
